# ─── Required by main.go (resource server) ────────────────────────────

# Signet issuer URL — must match the `iss` claim of the tokens you
# want to validate and the `issuer` field of its OIDC discovery document.
ISSUER_URL=https://auth.example.com

# Required `aud` claim value. Must be set unless SKIP_AUDIENCE_CHECK=1.
EXPECTED_AUDIENCE=

# Set to 1 to explicitly disable `aud` enforcement — use only when your
# issuer does NOT emit `aud` on access tokens. Accepting tokens without
# checking `aud` means any holder of a valid token can call this API,
# regardless of what service the token was issued for.
SKIP_AUDIENCE_CHECK=0

# Optional — overrides the Signet server's JWT_PRIVATE_CLAIM_PREFIX
# (default "extra"). Server and SDK must agree byte-for-byte; mismatched
# prefixes silently drop Domain/Project/ServiceAccount into Claims.Extras
# and fail any AccessRule covering those dimensions. Leave blank for the
# default "extra"; set, for example, JWT_PRIVATE_CLAIM_PREFIX=acme to
# read acme_domain / acme_project / acme_service_account.
JWT_PRIVATE_CLAIM_PREFIX=

# ─── Required by get-token.sh (Client Credentials helper) ─────────────
# Not used by main.go — it only validates tokens, never mints them.

CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# Space-separated scopes to request. Default "email profile" matches the
# Signet out-of-the-box scope set. Override with --scope on the CLI.
SCOPE=email profile

# Set to 1 to pass -k to curl (skip TLS verification). Dev only — useful
# when Signet runs with a self-signed certificate on localhost.
INSECURE=0
