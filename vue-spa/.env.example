# Copy to .env and fill in. Both required values are intentionally left blank:
# the app detects that and tells you what to set, instead of failing later with
# a confusing connectivity error.
#
# Vite only exposes variables prefixed with VITE_ to browser code, which is why
# these are named differently from the Go/Python examples (SIGNET_URL). Every
# value here is compiled into the public JavaScript bundle — never put a secret
# in this file.

# Signet issuer URL, e.g. https://auth.example.com
VITE_SIGNET_URL=

# OAuth 2.0 client identifier. Must be registered in Signet as a PUBLIC client
# (no client secret) — a secret shipped in a browser bundle is public by
# definition, and Signet requires PKCE for public clients anyway.
VITE_CLIENT_ID=

# Redirect URI registered for the client in Signet.
# Defaults to <origin>/callback when unset.
VITE_REDIRECT_URI=http://localhost:5173/callback

# Base URL prepended to API calls. Leave empty to call same-origin paths
# (/api/...), which the Vite dev server proxies to the go-webservice example
# on http://localhost:8080 — that server has no CORS, so the proxy is what
# makes browser calls to it possible.
VITE_API_BASE=
