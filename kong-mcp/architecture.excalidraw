    {
      "type": "rectangle", "id": "why_box",
      "x": 1466, "y": 352, "width": 408, "height": 188,
      "strokeColor": "#1e40af", "backgroundColor": "#dbeafe",
      "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
