    {
      "type": "text",
      "id": "title",
      "x": 150, "y": 36,
      "width": 960, "height": 38,
      "text": "kong-mcp  ·  Unified MCP OAuth Front Door",
      "originalText": "kong-mcp  ·  Unified MCP OAuth Front Door",
      "fontSize": 30, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#1e40af", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 100001, "version": 1, "versionNonce": 100002,
      "isDeleted": false, "groupIds": [], "boundElements": null,
      "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "text",
      "id": "subtitle",
      "x": 152, "y": 82,
      "width": 1180, "height": 20,
      "text": "A Kong go-pdk plugin (mcp-signet) that puts ONE OAuth front door before every MCP server — verified locally with RS256 + JWKS, then forwarded upstream.",
      "originalText": "A Kong go-pdk plugin (mcp-signet) that puts ONE OAuth front door before every MCP server — verified locally with RS256 + JWKS, then forwarded upstream.",
      "fontSize": 15, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#64748b", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 100003, "version": 1, "versionNonce": 100004,
      "isDeleted": false, "groupIds": [], "boundElements": null,
      "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "text",
      "id": "thesis",
      "x": 152, "y": 106,
      "width": 1260, "height": 20,
      "text": "Kong ADVERTISES where the flow lives (steps ② ③) and VERIFIES the token that comes back (step ⑤) — it never runs OAuth. The MCP client drives Auth Code + PKCE against Signet itself.",
      "originalText": "Kong ADVERTISES where the flow lives (steps ② ③) and VERIFIES the token that comes back (step ⑤) — it never runs OAuth. The MCP client drives Auth Code + PKCE against Signet itself.",
      "fontSize": 15, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#3b82f6", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 100005, "version": 1, "versionNonce": 100006,
